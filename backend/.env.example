# Copy these into Render environment variables
# Generate JWT secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

DATABASE_URL=postgresql://user:password@host:5432/bizgenie_db
JWT_SECRET=replace_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
